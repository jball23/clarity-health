# ─── Sanity ───────────────────────────────────────────────────────────────────
# Find these at https://sanity.io/manage → your project
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production

# Create a "Viewer" token at https://sanity.io/manage → API → Tokens
# Used for draft mode / visual editing
SANITY_API_READ_TOKEN=your_read_token_here

# Optional: browser token for real-time preview (same token is fine for demo)
NEXT_PUBLIC_SANITY_TOKEN=your_read_token_here

# ─── Plasmic ──────────────────────────────────────────────────────────────────
# Find these at https://studio.plasmic.app → your project → Settings → API tokens
NEXT_PUBLIC_PLASMIC_PROJECT_ID=your_plasmic_project_id
NEXT_PUBLIC_PLASMIC_PUBLIC_KEY=your_plasmic_public_key

# ─── Site ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
